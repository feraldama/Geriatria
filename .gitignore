# ─── Dependencias ───────────────────────────────────────────────────────────
node_modules/
.pnpm-store/

# ─── Builds / artefactos generados ──────────────────────────────────────────
dist/
build/
.next/
out/
*.tsbuildinfo
.turbo/

# Next.js: archivo de tipos autogenerado (se regenera con `next dev`/`build`)
next-env.d.ts

# ─── Entornos y secretos (NUNCA versionar) ──────────────────────────────────
.env
.env.local
.env.*.local
*.pem

# ─── Prisma ──────────────────────────────────────────────────────────────────
apps/api/prisma/*.db

# ─── Archivos subidos por usuarios (documentos clínicos) ─────────────────────
apps/api/storage/
uploads/

# ─── Tests / cobertura ───────────────────────────────────────────────────────
coverage/
.vitest/

# ─── Logs ──────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Herramientas / skills (reinstalables, no necesarias en el repo) ─────────
