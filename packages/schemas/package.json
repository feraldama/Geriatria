    "lint": "eslint ."
  },
  "dependencies": {
    "date-fns": "4.1.0",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "9.17.0",
    "@geriatria/config": "workspace:*",
    "eslint": "9.17.0",
    "tsup": "8.3.5",
    "typescript": "5.6.3",
    "typescript-eslint": "8.18.2"
  }
}
