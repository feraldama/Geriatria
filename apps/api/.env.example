# ─── Backend (apps/api) ───────────────────────────────────────────────────
# Copiá este archivo a `.env` y ajustá los valores. NUNCA versiones `.env`.

# Conexión a PostgreSQL. El operador define esta cadena en producción.
# En este entorno de desarrollo apunta al Postgres local (usuario postgres).
DATABASE_URL="postgresql://postgres:12345@localhost:5432/geriatria?schema=public"

# Puerto donde escucha la API.
PORT=4000

# Entorno: development | production
NODE_ENV=development

# Secreto para firmar los JWT. GENERÁ UNO PROPIO Y SECRETO en producción
# (por ej.: openssl rand -base64 48). Nunca uses este valor de ejemplo.
JWT_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"

# Vigencia del token de sesión.
JWT_EXPIRES_IN="8h"

# Flag Secure de la cookie de sesión. Poné true cuando sirvas por HTTPS.
# En desarrollo (http://localhost) debe ir en false.
COOKIE_SECURE=false

# Dominio del frontend permitido por CORS (separar varios con coma).
CORS_ORIGIN="http://localhost:3000"

# ─── Seed del administrador inicial ─────────────────────────────────────────
# Credenciales del primer usuario Administrador que crea el script de seed.
ADMIN_EMAIL="admin@geriatria.local"
ADMIN_PASSWORD="Admin12345"
ADMIN_NAME="Administrador"
