// Esquema de base de datos (Prisma + PostgreSQL).
//
// Fase 0: modelos de autenticación y RBAC (User, Role, Permission) + AuditLog.
// Los modelos clínicos (Patient, Consultation, etc.) se agregan en fases
// siguientes. Todos los registros llevan createdAt/updatedAt/deletedAt
// (borrado lógico) y createdById donde aplica.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────
// RBAC: usuarios, roles y permisos
// ─────────────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  photoUrl     String?
  active       Boolean   @default(true)
  // Preferencias de interfaz (tamaño de fuente, etc.) como JSON flexible.
  preferences  Json      @default("{}")

  roleId String
  role   Role   @relation(fields: [roleId], references: [id])

  // Protección contra fuerza bruta: contador de intentos fallidos y bloqueo.
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdById String?
  createdBy   User?   @relation("UserCreatedBy", fields: [createdById], references: [id])
  createdUsers User[] @relation("UserCreatedBy")

  createdPatients     Patient[]     @relation("PatientCreatedBy")
  createdAppointments Appointment[] @relation("AppointmentCreatedBy")

  auditLogs AuditLog[]

  @@index([email])
  @@index([deletedAt])
}

model Role {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  // Roles base del sistema (no se pueden borrar; sí editar permisos).
  isSystem    Boolean @default(false)

  permissions RolePermission[]
  users       User[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Permission {
  id          String  @id @default(cuid())
  // Acción en formato `recurso:acción`, ej. "patient:read".
  action      String  @unique
  description String

  roles RolePermission[]

  createdAt DateTime @default(now())
}

// Tabla puente N–N entre Role y Permission (permisos editables sin tocar código).
model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

// ─────────────────────────────────────────────────────────────────────────
// Pacientes (Fase 1)
// ─────────────────────────────────────────────────────────────────────────

enum Sex {
  MASCULINO
  FEMENINO
  OTRO
}

enum MaritalStatus {
  SOLTERO
  CASADO
  VIUDO
  DIVORCIADO
  UNION_LIBRE
  OTRO
}

// Nivel de dependencia para actividades de la vida diaria.
enum DependencyLevel {
  INDEPENDIENTE
  LEVE
  MODERADA
  SEVERA
  TOTAL
}

// Estado de un hábito (tabaco / alcohol).
enum HabitStatus {
  NUNCA
  EX
  ACTIVO
}

enum AllergySeverity {
  LEVE
  MODERADA
  SEVERA
}

enum AppointmentType {
  PRIMERA_VEZ
  CONTROL
  DOMICILIARIA
  TELECONSULTA
}

enum MedicationRoute {
  ORAL
  SUBLINGUAL
  INTRAVENOSA
  INTRAMUSCULAR
  SUBCUTANEA
  TOPICA
  INHALATORIA
  OFTALMICA
  OTICA
  RECTAL
  OTRA
}

enum MedicationStatus {
  ACTIVA
  SUSPENDIDA
}

enum DocumentCategory {
  LABORATORIO
  IMAGEN
  INTERCONSULTA
  ELECTROCARDIOGRAMA
  OTRO
}

enum AppointmentStatus {
  PROGRAMADA
  CONFIRMADA
  ATENDIDA
  AUSENTE
  CANCELADA
}

model Patient {
  id String @id @default(cuid())

  // Datos personales
  firstName  String
  lastName   String
  documentId String? // documento de identidad (cédula); puede faltar al alta

  // Texto de búsqueda normalizado (minúsculas y sin acentos) = nombre +
  // apellido + documento. Permite buscar "gonzalez" y encontrar "González".
  // Se mantiene en cada alta/edición desde la capa de aplicación.
  searchText String @default("")
  birthDate  DateTime
  sex        Sex
  maritalStatus MaritalStatus?
  photoUrl   String?

  // Contacto
  address  String?
  phone    String?
  phoneAlt String?
  email    String?

  // Contacto de emergencia
  emergencyName     String?
  emergencyPhone    String?
  emergencyRelation String?

  // Seguro / obra social / previsión
  insuranceProvider String?
  insuranceNumber   String?

  // Situación social
  livesWith        String? // con quién vive
  dependencyLevel  DependencyLevel?
  housingSituation String?

  // Antecedentes
  medicalHistory   String? @db.Text // patológicos
  surgicalHistory  String? @db.Text
  familyHistory    String? @db.Text
  smoking          HabitStatus?
  alcohol          HabitStatus?
  habitsNotes      String?
  notes            String? @db.Text

  // Relaciones
  caregivers    Caregiver[]
  conditions    Condition[]
  allergies     Allergy[]
  appointments  Appointment[]
  consultations Consultation[]
  vitalSigns    VitalSign[]
  medications   Medication[]
  documents     Document[]
  scales        AssessmentScale[]
  vaccinations  Vaccination[]
  carePlan      CarePlan?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdById String?
  createdBy   User?   @relation("PatientCreatedBy", fields: [createdById], references: [id])

  @@index([lastName, firstName])
  @@index([documentId])
  @@index([searchText])
  @@index([deletedAt])
}

// Cuidador / red de apoyo (clave en geriatría). Un paciente puede tener varios.
model Caregiver {
  id           String  @id @default(cuid())
  patientId    String
  patient      Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  name         String
  relationship String? // parentesco
  phone        String?
  livesWith    Boolean @default(false) // ¿convive con el paciente?
  isPrimary    Boolean @default(false) // ¿cuidador principal?
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
}

// Condición crónica / comorbilidad.
model Condition {
  id        String   @id @default(cuid())
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  name      String
  since     DateTime? // desde cuándo (aproximado)
  active    Boolean  @default(true)
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
}

// Alergia. Siempre se resalta en rojo en la interfaz.
model Allergy {
  id        String           @id @default(cuid())
  patientId String
  patient   Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  substance String // sustancia / fármaco
  reaction  String?
  severity  AllergySeverity?
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
}

// ─────────────────────────────────────────────────────────────────────────
// Agenda / Citas (Fase 2)
// ─────────────────────────────────────────────────────────────────────────

model Appointment {
  id String @id @default(cuid())

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  scheduledAt DateTime // fecha y hora de inicio (UTC)
  durationMin Int      @default(30)
  reason      String? // motivo de consulta
  type        AppointmentType   @default(CONTROL)
  status      AppointmentStatus @default(PROGRAMADA)
  notes       String?           @db.Text

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdById String?
  createdBy   User?   @relation("AppointmentCreatedBy", fields: [createdById], references: [id])

  // Una cita puede tener (opcionalmente) su consulta asociada (1–1).
  consultation Consultation?

  @@index([scheduledAt])
  @@index([patientId])
  @@index([status])
  @@index([deletedAt])
}

// ─────────────────────────────────────────────────────────────────────────
// Consultas (historia clínica) y signos vitales (Fase 3)
// ─────────────────────────────────────────────────────────────────────────

// Consulta en formato SOAP (Subjetivo, Objetivo, Análisis, Plan).
model Consultation {
  id String @id @default(cuid())

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  // Vínculo opcional 1–1 con la cita que originó la consulta.
  appointmentId String?      @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])

  date       DateTime @default(now())
  subjective String?  @db.Text // S: relato del paciente
  objective  String?  @db.Text // O: examen / hallazgos
  assessment String?  @db.Text // A: análisis / evaluación
  plan       String?  @db.Text // P: plan / indicaciones

  vitalSigns VitalSign[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String? // id del autor (sin relación; auditoría en AuditLog)

  @@index([patientId])
  @@index([date])
  @@index([deletedAt])
}

// Registro de signos vitales (con seguimiento en el tiempo).
model VitalSign {
  id String @id @default(cuid())

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  consultationId String?
  consultation   Consultation? @relation(fields: [consultationId], references: [id])

  measuredAt        DateTime @default(now())
  systolic          Int? // PA sistólica (mmHg)
  diastolic         Int? // PA diastólica (mmHg)
  heartRate         Int? // FC (lpm)
  respiratoryRate   Int? // FR (rpm)
  temperature       Float? // Tº (°C)
  oxygenSat         Int? // SatO2 (%)
  weight            Float? // peso (kg)
  height            Float? // talla (cm)
  bmi               Float? // IMC (calculado)
  calfCircumference Float? // circunferencia de pantorrilla (cm)
  notes             String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  @@index([patientId])
  @@index([measuredAt])
}

// ─────────────────────────────────────────────────────────────────────────
// Medicación (polifarmacia) — Fase 4
// ─────────────────────────────────────────────────────────────────────────

model Medication {
  id String @id @default(cuid())

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  drug         String // fármaco
  dose         String? // dosis (ej. "10 mg")
  frequency    String? // frecuencia (ej. "cada 8 h")
  route        MedicationRoute?
  startDate    DateTime? // fecha de inicio
  prescribedBy String? // indicado por

  status          MedicationStatus @default(ACTIVA)
  suspendedAt     DateTime? // fecha de suspensión
  suspendedReason String? // motivo de suspensión

  // Alerta/interacción marcada manualmente (se resalta en la conciliación).
  alertNote String?
  notes     String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?

  @@index([patientId])
  @@index([status])
  @@index([deletedAt])
}

// ─────────────────────────────────────────────────────────────────────────
// Documentos y estudios (Fase 5)
// ─────────────────────────────────────────────────────────────────────────

model Document {
  id String @id @default(cuid())

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  title     String
  category  DocumentCategory @default(OTRO)
  studyDate DateTime? // fecha de realización del estudio

  // Metadatos del archivo. storedPath es relativo a STORAGE_DIR.
  fileName  String // nombre original
  storedPath String // ruta relativa en el almacenamiento
  mimeType  String
  size      Int // bytes

  notes String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?

  @@index([patientId])
  @@index([category])
  @@index([deletedAt])
}

// ─────────────────────────────────────────────────────────────────────────
// Escalas de valoración geriátrica (Fase 6)
// ─────────────────────────────────────────────────────────────────────────

model AssessmentScale {
  id String @id @default(cuid())

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  type           String // BARTHEL, LAWTON, MMSE, YESAVAGE, ... (sin enum: extensible)
  score          Int
  maxScore       Int
  appliedAt      DateTime @default(now())
  answers        Json // respuestas individuales { questionId: value }
  interpretation String?
  notes          String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?

  @@index([patientId])
  @@index([type])
  @@index([deletedAt])
}

// ─────────────────────────────────────────────────────────────────────────
// Vacunación y plan de cuidados (Fase 8)
// ─────────────────────────────────────────────────────────────────────────

model Vaccination {
  id String @id @default(cuid())

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  vaccine      String // nombre de la vacuna
  doseDate     DateTime? // fecha de aplicación
  nextDoseDate DateTime? // próxima dosis
  notes        String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?

  @@index([patientId])
  @@index([nextDoseDate])
  @@index([deletedAt])
}

// Plan de cuidados activo (uno por paciente).
model CarePlan {
  id String @id @default(cuid())

  patientId String  @unique
  patient   Patient @relation(fields: [patientId], references: [id])

  objectives      String?   @db.Text
  indications     String?   @db.Text
  nextControls    String?   @db.Text
  nextControlDate DateTime? // próximo control (para alertas)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
}

// ─────────────────────────────────────────────────────────────────────────
// Auditoría
// ─────────────────────────────────────────────────────────────────────────

model AuditLog {
  id String @id @default(cuid())

  // Quién (puede ser null en intentos de login con email inexistente).
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  // Qué pasó: acción + recurso afectado.
  action   String // ej. "login.success", "login.failed", "user.update"
  resource String? // ej. "patient", "user"
  resourceId String?

  // Contexto adicional (cambios, email intentado, etc.) como JSON.
  metadata Json?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}
